# secrets.yaml.example — safe to commit, contains no real values
# Copy this file to secrets.yaml and add any real secrets below.
#
# This file is for REAL secrets only: API tokens, passwords, private keys.
# Device addresses, IDs, and physical parameters belong in config.yaml instead.
#
# Reference secrets in config.yaml using the !secret tag:
#   api_token: !secret some_api_token
#
# Or set them as environment variables:
#   export ENERGY_ASSISTANT_SECRET_SOME_API_TOKEN=value

# (no secrets required by default — add them here as needed)
# example:
# tibber_api_token: "<your-tibber-api-token>"
# ha_token: "<home-assistant-long-lived-access-token>"
