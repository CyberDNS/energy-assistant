# secrets.yaml.example — safe to commit, contains no real values
# Copy this file to secrets.yaml and fill in your values.
#
# Alternatively, export environment variables:
#   export ENERGY_ASSISTANT_SECRET_IOBROKER_HOST=192.168.x.x
#   export ENERGY_ASSISTANT_SECRET_IOBROKER_PORT=8087
#   export ENERGY_ASSISTANT_SECRET_TIBBER_HOME_ID=<your-home-id>

iobroker_host: "192.168.x.x"
iobroker_port: "8087"
tibber_home_id: "<your-tibber-home-id>"
