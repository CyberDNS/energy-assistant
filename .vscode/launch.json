{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Energy Controller (dry-run)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_controller.py",
      "args": ["--dry-run"],
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "serverReadyAction": {
        "pattern": "Web UI available at (http://localhost:\\d+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Energy Controller (live)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_controller.py",
      "args": [],
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "serverReadyAction": {
        "pattern": "Web UI available at (http://localhost:\\d+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
